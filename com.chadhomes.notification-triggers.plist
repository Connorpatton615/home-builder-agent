<?xml version="1.0" encoding="UTF-8"?>
<!--
  launchd job for the engine's automatic Event triggers.

  Fires daily at 7:05 AM — five minutes after the morning brief at 6 AM,
  so the brief sees Events from yesterday's fire, and the new fire produces
  Events that are immediately visible in the next iOS Notification feed
  fetch.

  Idempotent: hb-triggers dedupes by (project, category) over a 30-day
  lookback. Re-running won't double-emit.

  Install:
    cp com.chadhomes.notification-triggers.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.chadhomes.notification-triggers.plist

  Stop:
    launchctl unload ~/Library/LaunchAgents/com.chadhomes.notification-triggers.plist

  Reload after edits:
    launchctl unload ~/Library/LaunchAgents/com.chadhomes.notification-triggers.plist
    launchctl load   ~/Library/LaunchAgents/com.chadhomes.notification-triggers.plist

  Inspect:
    launchctl list | grep chadhomes
    tail -f /tmp/notification-triggers.stderr.log    # structured JSON
    tail -f /tmp/notification-triggers.stdout.log    # legacy text
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.chadhomes.notification-triggers</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>-c</string>
    <string>set -a; source /Users/connorpatton/Projects/home-builder-agent/.env; set +a; exec /Library/Frameworks/Python.framework/Versions/3.14/bin/hb-triggers</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/connorpatton/Projects/home-builder-agent</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PYTHONPATH</key>
    <string>/Users/connorpatton/Projects/home-builder-agent</string>
  </dict>

  <!-- 7:05 AM every day -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>7</integer>
    <key>Minute</key>
    <integer>5</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/tmp/notification-triggers.stdout.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/notification-triggers.stderr.log</string>
</dict>
</plist>
