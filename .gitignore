# SECRETS — never commit these. They unlock your Drive and Anthropic account.
.env
credentials.json
token.json
*.json.backup

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.Python
venv/
.venv/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Generated outputs (timelines, sample specs) — don't commit per-project content
timeline_*.md
*_timeline.md

# Watcher runtime state and logs — these change every minute, no value in versioning
.watcher_state.json
.inbox_watcher_state.json
.help_desk_state.json
.brief_announcements.json
.weather_cache.json
.meeting_proposals.json
.reconcile_watermark.json
.cost_log.jsonl
watcher.log
*.log

# Heartbeat-watchdog runtime state — written every successful watcher run
.heartbeats/

# Morning view-model launchd cache — written every 6:05 AM by hb-morning
.morning_cache/

# Claude Code worktrees — managed by Claude Code, not part of repo
.claude/worktrees/

# OS-level cruft
Thumbs.db
desktop.ini
